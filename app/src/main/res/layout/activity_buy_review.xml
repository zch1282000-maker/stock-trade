<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView style="@style/SectionTitle" android:text="一、基础信息"/>

        <TextView style="@style/FormLabel" android:text="1. 标的名称"/>
        <EditText android:id="@+id/et_stock_name" style="@style/FormEditText" android:hint="请输入股票名称"/>

        <TextView style="@style/FormLabel" android:text="2. 当前总账户总资产"/>
        <EditText android:id="@+id/et_total_assets" style="@style/FormEditText" android:hint="请输入金额" android:inputType="numberDecimal"/>

        <TextView style="@style/FormLabel" android:text="3. 本次买入金额"/>
        <EditText android:id="@+id/et_buy_amount" style="@style/FormEditText" android:hint="请输入金额" android:inputType="numberDecimal"/>

        <TextView style="@style/FormLabel" android:text="4. 本次买入后，该个股占总仓位比例（≤15%）"/>
        <EditText android:id="@+id/et_position_ratio" style="@style/FormEditText" android:hint="自动计算" android:focusable="false"/>

        <TextView style="@style/FormLabel" android:text="5. 股票波动率（%）"/>
        <EditText android:id="@+id/et_volatility" style="@style/FormEditText" android:hint="请输入波动率" android:inputType="numberDecimal"/>

        <TextView style="@style/FormLabel" android:text="6. 最大波动价值"/>
        <EditText android:id="@+id/et_volatility_value" style="@style/FormEditText" android:hint="自动计算" android:focusable="false"/>

        <TextView style="@style/FormLabel" android:text="7. 本次操作类型"/>
        <RadioGroup android:id="@+id/rg_operation_type" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <RadioButton android:id="@+id/rb_first" android:text="首次建仓" android:layout_weight="1"/>
            <RadioButton android:id="@+id/rb_add" android:text="加仓" android:layout_weight="1"/>
            <RadioButton android:id="@+id/rb_t" android:text="做T" android:layout_weight="1"/>
        </RadioGroup>

        <TextView style="@style/SectionTitle" android:text="二、买入核心逻辑"/>

        <TextView style="@style/FormLabel" android:text="1. 支撑上涨3条核心理由"/>
        <EditText android:id="@+id/et_reason1" style="@style/FormEditText" android:hint="①"/>
        <EditText android:id="@+id/et_reason2" style="@style/FormEditText" android:hint="②"/>
        <EditText android:id="@+id/et_reason3" style="@style/FormEditText" android:hint="③"/>

        <TextView style="@style/FormLabel" android:text="2. 本次持仓周期规划"/>
        <RadioGroup android:id="@+id/rg_cycle" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <RadioButton android:id="@+id/rb_short" android:text="短线" android:layout_weight="1"/>
            <RadioButton android:id="@+id/rb_mid" android:text="中线" android:layout_weight="1"/>
            <RadioButton android:id="@+id/rb_long" android:text="长线" android:layout_weight="1"/>
        </RadioGroup>

        <TextView style="@style/SectionTitle" android:text="三、风险测算"/>

        <TextView style="@style/FormLabel" android:text="1. 单只个股最大容忍亏损比例"/>
        <EditText android:id="@+id/et_max_loss" style="@style/FormEditText" android:hint="请输入百分比" android:inputType="numberDecimal"/>

        <TextView style="@style/FormLabel" android:text="2. 硬性止损价格"/>
        <EditText android:id="@+id/et_stop_price" style="@style/FormEditText" android:hint="请输入价格" android:inputType="numberDecimal"/>

        <TextView style="@style/FormLabel" android:text="3. 3个潜在重大利空"/>
        <EditText android:id="@+id/et_risk1" style="@style/FormEditText" android:hint="①"/>
        <EditText android:id="@+id/et_risk2" style="@style/FormEditText" android:hint="②"/>
        <EditText android:id="@+id/et_risk3" style="@style/FormEditText" android:hint="③"/>

        <TextView style="@style/FormLabel" android:text="4. 极端情况评估：如果跌到止损位，这笔亏损会不会影响日常生活、睡眠心态？"/>
        <RadioGroup android:id="@+id/rg_extreme" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <RadioButton android:id="@+id/rb_extreme_yes" android:text="会" android:layout_weight="1"/>
            <RadioButton android:id="@+id/rb_extreme_no" android:text="不会" android:layout_weight="1"/>
        </RadioGroup>

        <TextView style="@style/SectionTitle" android:text="四、仓位约束"/>

        <TextView style="@style/FormLabel" android:text="1. 单只个股总仓位上限：≤15%"/>
        <TextView style="@style/FormLabel" android:text="2. 全仓短线投机个股总仓位上限：≤20%"/>
        <TextView style="@style/FormLabel" android:text="3. 账户整体浮亏超8%，是否执行加仓？"/>
        <RadioGroup android:id="@+id/rg_position_add" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <RadioButton android:id="@+id/rb_position_add_yes" android:text="是" android:layout_weight="1"/>
            <RadioButton android:id="@+id/rb_position_add_no" android:text="否" android:layout_weight="1"/>
        </RadioGroup>

        <TextView style="@style/SectionTitle" android:text="五、止盈规划"/>

        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView style="@style/FormLabel" android:text="1. 第一止盈目标价"/>
            <EditText android:id="@+id/et_first_target" style="@style/FormEditText" android:hint="价格" android:layout_weight="1" android:inputType="numberDecimal"/>
            <TextView style="@style/FormLabel" android:text="到达减仓"/>
            <EditText android:id="@+id/et_first_ratio" style="@style/FormEditText" android:hint="%" android:layout_width="80dp" android:inputType="numberDecimal"/>
        </LinearLayout>

        <TextView style="@style/FormLabel" android:text="2. 第二止盈目标价"/>
        <EditText android:id="@+id/et_second_target" style="@style/FormEditText" android:hint="到达清仓剩余筹码" android:inputType="numberDecimal"/>

        <TextView style="@style/FormLabel" android:text="3. 中途上涨后心态失控追高预案"/>
        <EditText android:id="@+id/et_chase_plan" style="@style/FormEditText" android:hint="请输入预案内容"/>

        <TextView style="@style/SectionTitle" android:text="六、情绪自查（取消所有勾选后才能提交）"/>

        <CheckBox android:id="@+id/cb_emotion1" android:text="刚大涨，眼红追涨" style="@style/CheckboxText"/>
        <CheckBox android:id="@+id/cb_emotion2" android:text="连续亏损，急于回本加仓摊薄" style="@style/CheckboxText"/>
        <CheckBox android:id="@+id/cb_emotion3" android:text="刷短视频、股吧、群聊听别人推荐" style="@style/CheckboxText"/>
        <CheckBox android:id="@+id/cb_emotion4" android:text="熬夜、烦躁、焦虑、心态浮躁时操作" style="@style/CheckboxText"/>
        <CheckBox android:id="@+id/cb_emotion5" android:text="短期连续盈利，自我膨胀想重仓梭哈" style="@style/CheckboxText"/>
        <CheckBox android:id="@+id/cb_emotion6" android:text="急于快速赚钱，追求短期暴利" style="@style/CheckboxText"/>
        <CheckBox android:id="@+id/cb_emotion7" android:text="害怕踏空，不分析逻辑直接买入" style="@style/CheckboxText"/>

        <TextView style="@style/FormLabel" android:text="确认情绪自查无问题"/>
        <RadioGroup android:id="@+id/rg_emotion_confirm" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <RadioButton android:id="@+id/rb_emotion_yes" android:text="确认无问题" android:layout_weight="1"/>
            <RadioButton android:id="@+id/rb_emotion_no" android:text="仍有问题" android:layout_weight="1"/>
        </RadioGroup>

        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">
            <Button android:id="@+id/submit_btn" android:text="@string/submit" android:layout_weight="1" android:layout_height="48dp" android:background="@color/green_500" android:textColor="@color/white"/>
            <Button android:id="@+id/cancel_btn" android:text="@string/cancel" android:layout_weight="1" android:layout_height="48dp" android:layout_marginLeft="16dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
