<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView style="@style/SectionTitle" android:text="一、基础信息"/>

        <TextView style="@style/FormLabel" android:text="1. 标的名称"/>
        <EditText android:id="@+id/et_stock_name" style="@style/FormEditText" android:hint="请输入股票名称"/>

        <TextView style="@style/FormLabel" android:text="2. 当前持仓成本"/>
        <EditText android:id="@+id/et_cost" style="@style/FormEditText" android:hint="请输入成本价" android:inputType="numberDecimal"/>

        <TextView style="@style/FormLabel" android:text="3. 当前浮盈/浮亏"/>
        <EditText android:id="@+id/et_profit_loss" style="@style/FormEditText" android:hint="请输入金额或百分比"/>

        <TextView style="@style/FormLabel" android:text="4. 卖出比例"/>
        <RadioGroup android:id="@+id/rg_sell_ratio" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <RadioButton android:id="@+id/rb_partial" android:text="部分减仓" android:layout_weight="1"/>
            <RadioButton android:id="@+id/rb_all" android:text="全部清仓" android:layout_weight="1"/>
        </RadioGroup>

        <TextView style="@style/SectionTitle" android:text="二、卖出核心依据"/>

        <TextView style="@style/FormLabel" android:text="情况1：止盈卖出"/>

        <TextView style="@style/FormLabel" android:text="1. 是否到达预设止盈目标"/>
        <RadioGroup android:id="@+id/rg_profit_target" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <RadioButton android:id="@+id/rb_profit_target_yes" android:text="是" android:layout_weight="1"/>
            <RadioButton android:id="@+id/rb_profit_target_no" android:text="否" android:layout_weight="1"/>
        </RadioGroup>

        <TextView style="@style/FormLabel" android:text="2. 逻辑是否兑现完毕"/>
        <EditText android:id="@+id/et_logic_fulfilled" style="@style/FormEditText" android:hint="请输入说明"/>

        <TextView style="@style/FormLabel" android:text="情况2：止损/逻辑破坏卖出"/>

        <TextView style="@style/FormLabel" android:text="1. 是否跌破预设止损线"/>
        <RadioGroup android:id="@+id/rg_stop_loss" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <RadioButton android:id="@+id/rb_stop_loss_yes" android:text="是" android:layout_weight="1"/>
            <RadioButton android:id="@+id/rb_stop_loss_no" android:text="否" android:layout_weight="1"/>
        </RadioGroup>

        <TextView style="@style/FormLabel" android:text="2. 当初买入逻辑是否彻底失效"/>
        <EditText android:id="@+id/et_logic_disappear" style="@style/FormEditText" android:hint="①原有上涨逻辑消失点"/>
        <EditText android:id="@+id/et_irreversible_negative" style="@style/FormEditText" android:hint="②个股/行业出现不可逆利空"/>

        <TextView style="@style/SectionTitle" android:text="三、情绪自查（取消所有勾选后才能提交）"/>

        <CheckBox android:id="@+id/cb_emotion1" android:text="短期大跌恐慌，害怕继续下跌无脑割肉" style="@style/CheckboxText"/>
        <CheckBox android:id="@+id/cb_emotion2" android:text="小幅回撤，承受不住波动急于卖出" style="@style/CheckboxText"/>
        <CheckBox android:id="@+id/cb_emotion3" android:text="小幅盈利，拿不住一点利润就跑路" style="@style/CheckboxText"/>
        <CheckBox android:id="@+id/cb_emotion4" android:text="看到其他股票大涨，想换股操作" style="@style/CheckboxText"/>

        <TextView style="@style/FormLabel" android:text="确认情绪自查无问题"/>
        <RadioGroup android:id="@+id/rg_emotion_confirm" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <RadioButton android:id="@+id/rb_emotion_yes" android:text="确认无问题" android:layout_weight="1"/>
            <RadioButton android:id="@+id/rb_emotion_no" android:text="仍有问题" android:layout_weight="1"/>
        </RadioGroup>

        <TextView style="@style/SectionTitle" android:text="四、后续预案"/>

        <TextView style="@style/FormLabel" android:text="1. 卖出后是否立刻换其他个股买入"/>
        <RadioGroup android:id="@+id/rg_switch" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <RadioButton android:id="@+id/rb_switch_yes" android:text="是" android:layout_weight="1"/>
            <RadioButton android:id="@+id/rb_switch_no" android:text="否" android:layout_weight="1"/>
        </RadioGroup>

        <TextView style="@style/FormLabel" android:text="2. 后续重新买回的条件"/>
        <EditText android:id="@+id/et_buy_back_condition" style="@style/FormEditText" android:hint="请输入条件"/>

        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">
            <Button android:id="@+id/submit_btn" android:text="@string/submit" android:layout_weight="1" android:layout_height="48dp" android:background="@color/green_500" android:textColor="@color/white"/>
            <Button android:id="@+id/cancel_btn" android:text="@string/cancel" android:layout_weight="1" android:layout_height="48dp" android:layout_marginLeft="16dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
